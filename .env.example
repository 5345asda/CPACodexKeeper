# CPA management API base URL / CPA 管理 API 地址
CPA_ENDPOINT=https://your-cpa-endpoint

# CPA management token / bearer credential / CPA 管理 token
CPA_TOKEN=your-management-token

# Optional HTTP/HTTPS proxy, for example: http://127.0.0.1:7890
# 可选 HTTP/HTTPS 代理，例如：http://127.0.0.1:7890
CPA_PROXY=

# Daemon loop interval in seconds / 守护模式轮询间隔（秒）
CPA_INTERVAL=1800

# Disable threshold percentage / 禁用阈值百分比
# The token will be disabled only when the checked quota reaches this value
# 只有当检查到的限额达到该值时才会禁用 token
CPA_QUOTA_THRESHOLD=100

# Refresh threshold in days / 刷新阈值（天）
# Disabled tokens with remaining lifetime below this value can be refreshed
# 剩余有效期低于该值的已禁用 token 会进入刷新判断
CPA_EXPIRY_THRESHOLD_DAYS=3

# Whether automatic refresh is enabled / 是否启用自动刷新
# When enabled, keeper refreshes only disabled tokens; enabled tokens are left to CPA
# 开启后 keeper 只刷新已禁用 token；启用状态 token 交给 CPA 处理
# Default is true, but keeper still refreshes only disabled tokens
# 默认开启，但 keeper 仍只刷新已禁用 token
CPA_ENABLE_REFRESH=true

# Timeout for CPA API requests in seconds / CPA API 请求超时（秒）
CPA_HTTP_TIMEOUT=30

# Timeout for OpenAI usage requests in seconds / OpenAI usage 请求超时（秒）
CPA_USAGE_TIMEOUT=15

# Retry count for transient network/server failures / 临时网络或服务端错误重试次数
CPA_MAX_RETRIES=2

# Number of concurrent worker threads / 并发 worker 线程数
# Each token is still logged as a single block to avoid interleaved output
# 每个 token 的日志仍会按块输出，避免并发时控制台内容交错
CPA_WORKER_THREADS=8

# Keeper management UI listen host and port / Keeper 管理面板监听地址和端口
# Daemon mode starts the UI by default. Use --no-web to disable it.
# 守护模式默认启动管理面板；可用 --no-web 关闭。
# For direct host runs, keep this local-only unless you also set CPA_UI_TOKEN.
# 直接在宿主机运行时建议仅监听本机；如需公网访问，请同时设置 CPA_UI_TOKEN。
CPA_UI_HOST=127.0.0.1
CPA_UI_PORT=8318

# Bearer token for Keeper UI write operations / 管理面板写操作 Bearer Token
# Leave empty for read-only UI. Set this before using scan/config/token actions.
# 留空时面板只读；如需巡检、改配置或操作 token，请先设置此值。
# If set, enter this token in the UI key button.
# 填写后通过面板右上角钥匙按钮输入。
CPA_UI_TOKEN=

# Runtime overrides written by the UI / UI 写入的运行时覆盖配置
# Defaults to runtime.json in the project directory when unset.
# 不设置时默认写入项目目录下 runtime.json。
CPA_RUNTIME_OVERRIDES=
